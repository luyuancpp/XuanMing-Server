# Pandora team 生产配置【模板】。cp team-prod.yaml.example team-prod.yaml 填真值后部署。
# ⚠️ 真实 team-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;timeout 收紧;redis 加密码;kafka 真实 brokers。

server:
  grpc:
    network: tcp
    addr: ":50010"
    timeout: "5s"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51010"

node:
  zone_id: 1
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"
    read_timeout: "1s"
    write_timeout: "1s"

kafka:
  brokers: ["__KAFKA_BROKER_1__:9092", "__KAFKA_BROKER_2__:9092"]
  dial_timeout: "2s"
  write_timeout: "5s"
  idempotent: true

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

team:
  invite_ttl: "60s"
  disbanded_retention: "5m"
  active_ttl: "60m"
  max_members: 5
  optimistic_retry: 3
