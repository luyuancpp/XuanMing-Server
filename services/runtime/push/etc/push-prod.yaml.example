# Pandora push 生产配置【模板】。cp push-prod.yaml.example push-prod.yaml 填真值后部署。
# ⚠️ 真实 push-prod.yaml 被 services/.gitignore 忽略,只提交本 .example。
# 与 dev 差异:删 enable_reflection;redis 加密码;kafka 真实 brokers。

server:
  grpc:
    network: tcp
    addr: ":50014"
    # enable_reflection 不写 = false
  http:
    network: tcp
    addr: ":51014"

node:
  zone_id: 1
  session_expire_min: 1440
  redis_client:
    host: "__REDIS_HOST__:6379"
    password: "__REDIS_PASSWORD__"
    db: 0
    dial_timeout: "2s"

kafka:
  brokers: ["__KAFKA_BROKER_1__:9092", "__KAFKA_BROKER_2__:9092"]
  group_id: "pandora-push"
  partition_cnt: 4
  dial_timeout: "2s"
  read_timeout: "10s"
  write_timeout: "10s"
  channel_buffer: 1024
  idempotent: true

snowflake:
  epoch: 1773446400
  node_bits: 17
  step_bits: 15

push:
  # 订阅 topic 列表;不填走 kafkax.PushTopics 默认,但显式列出会覆盖默认,新增 topic 必须同步补全。
  # 2026-06-15 friend 服务上线,补 pandora.friend.event。
  # 2026-06-15 hub_allocator 强制整合上线,补 pandora.hub.migrate(大厅迁移通知)。
  # 2026-06-16 chat 三频道补全,补 pandora.chat.team(队伍)/ pandora.chat.world(世界广播)。
  topics:
    - "pandora.team.update"
    - "pandora.match.progress"
    - "pandora.chat.private"
    - "pandora.chat.team"
    - "pandora.chat.world"
    - "pandora.friend.event"
    - "pandora.hub.migrate"
  offline_cache_ttl: "5m"
