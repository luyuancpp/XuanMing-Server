# Pandora dialogue 服务生产配置样例(2026-06-16)。复制为 dialogue-prod.yaml 后按环境填值。
#
# - gRPC :50013 / HTTP :51013(仅 /metrics)
# - prod: enable_reflection 不写(零值 false)= 关闭 grpc reflection
#
# 阶段限制:当前对话树内联在配置、会话为单实例内存。生产若多实例:
#   1) 对话树改接配置中心 / mysql dialogue_trees(json blob)热更;
#   2) SessionStore 换 Redis 版(biz / service 不动)。
# 上述两项落地前,prod 单实例运行,对话树仍可走本文件内联。

server:
  grpc:
    network: tcp
    addr: ":50013"
    timeout: "5s"
    # enable_reflection 省略 = 关闭(prod 默认)
  http:
    network: tcp
    addr: ":51013"

node:
  zone_id: 1

dialogue:
  session_ttl: "5m"
  # trees: 生产对话树。示例见 dialogue-dev.yaml;此处按运营文案填充。
  trees: []
