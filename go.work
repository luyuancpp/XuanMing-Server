go 1.26.4

// Pandora Go workspace
//
// W1-D2 阶段:只 use ./pkg(公共框架已落地)。
// W2 起 13 个业务服务 + push 服务按业务域归位到 services/ 下。
//
// 目录决策(2026-06-05 重构):按业务域分组(对齐大厂 + kafka topic 域)
//   - services/account/         账号身份(login, player)
//   - services/social/          社交(friend, chat, dialogue)
//   - services/matchmaking/     匹配组队(team, matchmaker)
//   - services/battle/          战斗调度(ds_allocator, hub_allocator, battle_result)
//   - services/economy/         经济(trade)
//   - services/data/            数据层(data_service)
//   - services/runtime/         运行时(player_locator, push)
//
// Go module 路径示例:github.com/luyuancpp/pandora/services/account/login
//
// Go 版本:跟 HANDOFF.md "Go 版本 go1.26.4" 锁定一致。
// 历史背景:W1 PROGRESS.md 写目标 1.23,W2 依赖(Kratos v2.9.2 / sarama 1.43.1 等)
// 自动要求 1.24.0;W3 ① 升 1.25(jwt/v5、go-redis/v9 链路);W3 ⑥(2026-06-05 Codex 审查)
// 统一到本机 toolchain 1.26.4,避免文档与工程冲突。再升级须同步 HANDOFF.md。

use ./pkg

use ./proto

use ./services/account/login

use ./services/account/player

use ./services/social/friend

use ./services/social/chat

use ./services/social/dialogue

use ./services/runtime/push

use ./services/runtime/player_locator

use ./services/matchmaking/team

use ./services/matchmaking/matchmaker

use ./services/battle/ds_allocator

use ./services/battle/hub_allocator

use ./services/battle/battle_result

use ./services/economy/trade

use ./services/economy/inventory

use (
	./pkg/killswitch/etcdkv
	./services/data/data_service
)

// ⚠️ 构建验证:仓库根没有 go.mod,不能在根目录跑 go build ./...
// 正确做法:按 use 列表构建,例如 go build ./pkg/...
// W2+ 每新增一个 use,同步追加到 CLAUDE.md §4.1 的验证命令中
//
// W2+ 启用以下 use 行(每个服务在 cmd/main.go + go.mod 创建后启用):
//
// use ./services/account/login          ← W2 ③ 已启用
// use ./services/runtime/push           ← W2 ⑤ 已启用(Kratos transport/grpc server stream)
// use ./services/runtime/player_locator ← W3 ⑤ 已启用(Kratos unary,Redis 强依赖)
// use ./services/account/player
// use ./services/social/friend            ← 2026-06-15 已启用(MySQL pandora_social + kafka friend.event + locator 在线状态)
// use ./services/social/chat
// use ./services/social/dialogue
// use ./services/matchmaking/team          ← W3 ⑦ 已启用(见 line 34)
// use ./services/matchmaking/matchmaker     ← W4 ① 已启用
// use ./services/battle/ds_allocator        ← W4 ② 已启用
// use ./services/battle/hub_allocator
// use ./services/battle/battle_result        ← W4 ③ 已启用
